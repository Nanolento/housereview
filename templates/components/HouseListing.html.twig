<div {{ attributes }} class="flex flex-col max-w-2xl mx-auto rounded-lg bg-white
                             shadow-md outline outline-black/5">
  <h1 class="text-xl m-4 mb-2 font-bold">{{ house.title|default('(Title missing)') }}</h1>
  <div class="tableSect bg-gray-100 flex flex-row justify-between mt-2 py-[2px] w-full">
    <div class="tableCol">
      <p>Surface Area: {{ house.areaString }}</p>
      <p>Rent: {{ house.monthlyRent }}</p>
      <p>City: {{ house.city }}</p>
    </div>
    <div class="tableCol">
      <p>Energy Label: {{ house.energyLabel|default('(Energy label missing)') }}</p>
      <p>Room Count: {{ house.roomCountString }}</p>
      <p>Status: {{ house.status.value }}</p>
    </div>
  </div>
  <div class="gradeSect bg-gray-50 flex flex-row justify-evenly px-4 py-2">
    {% if house.titleGrade.value == 'Good' %}
    {% set color = 'gradeGoodColor' %}
    {% elseif house.titleGrade.value == 'Warning' %}
    {% set color = 'gradeWarnColor' %}
    {% else %}
    {% set color = 'gradeBadColor' %}
    {% endif %}
    <!-- Note: the fractions you see here are for the following layout:
         2/3 for the individual grades. 2/9 per 1 of the 3 grades.
         1/3 for the overall grade. -->
    <p class="w-2/9">Title <span class="{{ color }} gradeChip">{{ house.titleGrade.value }}</span></p>
    {% if house.rentGrade.value == 'Good' %}
    {% set color = 'gradeGoodColor' %}
    {% elseif house.rentGrade.value == 'Warning' %}
    {% set color = 'gradeWarnColor' %}
    {% else %}
    {% set color = 'gradeBadColor' %}
    {% endif %}
    <p class="w-2/9">Rent <span class="{{ color }} gradeChip">{{ house.rentGrade.value }}</span></p>
    {% if house.energyGrade.value == 'Good' %}
    {% set color = 'gradeGoodColor' %}
    {% elseif house.energyGrade.value == 'Warning' %}
    {% set color = 'gradeWarnColor' %}
    {% else %}
    {% set color = 'gradeBadColor' %}
    {% endif %}
    <p class="w-2/9">Energy <span class="{{ color }} gradeChip">{{ house.energyGrade.value }}</span></p>
    {% if house.overallGrade.value == 'Good' %}
    {% set color = 'gradeGoodColor' %}
    {% elseif house.overallGrade.value == 'Warning' %}
    {% set color = 'gradeWarnColor' %}
    {% else %}
    {% set color = 'gradeBadColor' %}
    {% endif %}
    <p class="w-1/3">Overall <span class="{{ color }} gradeChip">{{ house.overallGrade.totalScoreLabel }}</span></p>
  </div>
  <div class="controlSect">
    {% if house.status.value == 'Pending' %}
    <button {{ live_action('approveHouse') }}>Approve</button>
    <button {{ live_action('rejectHouse') }}>Reject</button>
    {% elseif house.status.value == 'Approved' %}
    <button {{ live_action('resetHouseStatus') }}>Unapprove</button>
    {% elseif house.status.value == 'Rejected' %}
    <button {{ live_action('resetHouseStatus') }}>Unreject</button>
    {% endif %}
  </div>
</div>
